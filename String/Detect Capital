//Count uppercase letters and validate based on allowed capital patterns.

class Solution {
    public boolean detectCapitalUse(String word) {
        int count = 0;

        for(int i = 0;i < word.length();i++) {                 //checking capital letter if present count 1+
            if(Character.isUpperCase(word.charAt(i))) {
                count++;
            }
        } 
        if(count == word.length()) return true;            // if all letters is capital
        if(count == 0) return true;                        //non letters is capital
        if(count == 1 && Character.isUpperCase(word.charAt(0))) return true;     //first letter is capital

        return false;
    }
}
    
           
