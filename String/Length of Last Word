class Solution {
    public int lengthOfLastWord(String s) {
       int counter = 0;
       int i = s.length() - 1;

       while(i >= 0 && s.charAt(i) == ' ') {  //skip spaces from ed
        i--;
       } 

       while(i>= 0 && s.charAt(i) != ' ') {  // count last word
        counter++;
        i--;
       }

       return counter;
    }
}
